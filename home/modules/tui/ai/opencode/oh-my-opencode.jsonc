{
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",

    "agents": {
        "sisyphus": {
            "model": "anthropic/claude-opus-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "sisyphus-junior": {
            "model": "anthropic/claude-sonnet-4-6",
            "variant": "high",
            "fallback_models": [],
        },
        "oracle": {
            "model": "anthropic/claude-sonnet-4-6",
            "variant": "high",
            "fallback_models": [],
        },
        "explore": {
            "model": "anthropic/claude-haiku-4-5",
            "fallback_models": [],
        },
        "librarian": {
            "model": "anthropic/claude-haiku-4-5",
            "fallback_models": [],
        },
        "prometheus": {
            "model": "anthropic/claude-opus-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "multimodal-looker": {
            "model": "anthropic/claude-sonnet-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
    },

    "categories": {
        "quick": {
            "model": "anthropic/claude-haiku-4-5",
            "fallback_models": [],
        },
        "unspecified-low": {
            "model": "anthropic/claude-sonnet-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "unspecified-high": {
            "model": "anthropic/claude-opus-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "writing": {
            "model": "anthropic/claude-sonnet-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "visual-engineering": {
            "model": "anthropic/claude-sonnet-4-6",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "ultrabrain": {
            "model": "anthropic/claude-sonnet-4-6",
            "variant": "xhigh",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
        "deep": {
            "model": "anthropic/claude-opus-4-6",
            "variant": "medium",
            "fallback_models": ["anthropic/claude-sonnet-4-6"],
        },
    },

    "background_task": {
        "providerConcurrency": {
            "github-copilot": 5,
        },
    },

    "runtime_fallback": {
        "enabled": true,
        "max_fallback_attempts": 3,
        "notify_on_fallback": true,
    },

    "experimental": {
        "aggressive_truncation": true,
    },
}
